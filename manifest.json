{
  "manifest_version": 3,
  "name": "OKStudy",
  "version": "1.2.1",
  "description": "Make studying OK again - tryb Tłumacz (krok po kroku) lub Express, Gemini Vision, skróty Alt+O/I/P/K/M",
  "permissions": ["storage", "activeTab", "tabs"],
  "host_permissions": [
    "https://generativelanguage.googleapis.com/*"
  ],
  "options_page": "options.html",
  "action": {
    "default_title": "OKStudy - ustawienia"
  },
  "commands": {
    "solve_fast": {
      "suggested_key": {
        "default": "Alt+O",
        "mac": "Alt+O"
      },
      "description": "Szybka analiza (bez internetu)"
    },
    "solve_internet": {
      "suggested_key": {
        "default": "Alt+I",
        "mac": "Alt+I"
      },
      "description": "Dokładna analiza (z internetem)"
    },
    "repeat_last": {
      "suggested_key": {
        "default": "Alt+P",
        "mac": "Alt+P"
      },
      "description": "Powtórz ostatnią odpowiedź"
    },
    "cancel": {
      "suggested_key": {
        "default": "Alt+K",
        "mac": "Alt+K"
      },
      "description": "Przerwij / kasuj bieżącą analizę"
    },
    "toggle_model": {
      "description": "Przełącz model Flash/Pro (ustaw skrót ręcznie, np. Alt+M)"
    },
    "solve_alt": {
      "description": "Szybka analiza - zapasowy skrót (ustaw ręcznie, np. Alt+A, gdy Alt+O zajęte)"
    }
  },
  "background": {
    "service_worker": "js/background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["js/content.js"],
      "run_at": "document_end"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
